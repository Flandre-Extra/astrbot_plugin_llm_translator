{
    "source_lang": {
        "type": "string",
        "description": "源语言",
        "default": "中文"
    },
    "target_lang": {
        "type": "string",
        "description": "目标语言",
        "default": "日语"
    },
    "send_original": {
        "type": "bool",
        "description": "追发原文",
        "hint": "翻译完成后单独发送一条原文消息作为字幕",
        "default": false
    },
    "text_filter_regex": {
        "type": "string",
        "description": "正则过滤",
        "hint": "自定义正则过滤文本内容，匹配到的内容会在翻译前被移除。留空则不过滤。示例：（[^（）]*）|\\([^()]*\\)|【[^【】]*】|\\[[^\\[\\]]*\\]|「[^「」]*」|『[^『』]*』",
        "default": ""
    },
    "api_base": {
        "type": "string",
        "description": "API 端点",
        "hint": "兼容 OpenAI 格式。留空则自动匹配 AstrBot 当前聊天模型的配置",
        "default": ""
    },
    "api_key": {
        "type": "string",
        "description": "API Key",
        "hint": "留空则自动使用 AstrBot 当前聊天模型的 Key",
        "default": ""
    },
    "api_model": {
        "type": "string",
        "description": "翻译模型名",
        "hint": "留空则自动使用 AstrBot 当前聊天模型的配置",
        "default": ""
    },
    "timeout": {
        "type": "int",
        "description": "请求超时（秒）",
        "hint": "翻译 API 的最大等待时间",
        "default": 30
    },
    "max_tokens": {
        "type": "int",
        "description": "输出上限",
        "hint": "翻译结果的最大 token 数，长文本可调大",
        "default": 4096
    }
}
